# ─── Neon PostgreSQL (required for production) ───────────────────────────────
# Get these from your Neon console at https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxxxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxxxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ─── Optional: AI SDK (z-ai-web-dev-sdk) ─────────────────────────────────────
# ZAI_SDK_API_KEY=""
# ZAI_SDK_BASE_URL=""