# BranchBoard - Environment Variables Template
# Copy this file to .env and fill in the real values before running the app.

# ─── Neon PostgreSQL ─────────────────────────────────────────────────────────
# Connection URL (with pgbouncer for serverless)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR_PROJECT_NAME.region.aws.neon.tech/branchboard?sslmode=require&pgbouncer=true"
# Direct connection URL (for migrations)
DIRECT_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR_PROJECT_NAME.region.aws.neon.tech/branchboard?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Optional ────────────────────────────────────────────────────────────────
# Z.AI Web Dev SDK (for AI features)
# Z_AI_API_KEY=""
