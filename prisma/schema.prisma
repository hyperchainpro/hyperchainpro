generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  avatar          String?
  passwordHash    String?
  role            String           @default("USER")
  isActive        Boolean          @default(true)
  resetToken      String?
  resetTokenExpiry DateTime?
  language        String           @default("en")
  theme           String           @default("system")
  accentColor     String           @default("#6366f1")
  aiSettings      String?
  lastLoginAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  boardMembers      BoardMember[]
  commits           Commit[]
  authoredMRs       MergeRequest[]   @relation("AuthoredMergeRequest")
  mergeComments     MergeComment[]
  auditLogs         AuditLog[]
  communityDesigns  CommunityDesign[]
  aiAgents          AIAgent[]
  sentInvites       BoardInvite[]    @relation("SentInvites")

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model Board {
  id                String           @id @default(cuid())
  name              String
  description       String?
  ownerId           String
  isPublic          Boolean          @default(false)
  thumbnail         String?
  defaultBranch     String           @default("main")
  branchProtection  Boolean          @default(false)
  minReviewers      Int              @default(1)
  deviceType        String?
  deviceId          String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  members           BoardMember[]
  branches          Branch[]
  commits           Commit[]
  mergeRequests     MergeRequest[]
  comments          BoardComment[]
  elements          BoardElement[]
  invites           BoardInvite[]

  @@index([ownerId])
  @@index([createdAt])
}

model BoardMember {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  role      String   @default("VIEWER")
  joinedAt  DateTime @default(now())

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model Branch {
  id              String           @id @default(cuid())
  boardId         String
  name            String
  isDefault       Boolean          @default(false)
  createdAt       DateTime         @default(now())

  board           Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  commits         Commit[]
  sourceMRs       MergeRequest[]   @relation("MRSourceBranch")
  targetMRs       MergeRequest[]   @relation("MRTargetBranch")

  @@unique([boardId, name])
}

model Commit {
  id        String    @id @default(cuid())
  boardId   String
  branchId  String
  authorId  String
  message   String
  tag       String?
  snapshot  String
  parentId  String?
  createdAt DateTime  @default(now())

  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])
  parent    Commit?   @relation("CommitParent", fields: [parentId], references: [id])
  children  Commit[]  @relation("CommitParent")

  @@index([boardId, createdAt])
  @@index([branchId])
}

model MergeRequest {
  id              String        @id @default(cuid())
  boardId         String
  sourceBranchId  String
  targetBranchId  String
  title           String
  description     String?
  authorId        String
  status          String        @default("OPEN")
  conflictData    String?
  createdAt       DateTime      @default(now())
  resolvedAt      DateTime?

  board           Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  sourceBranch    Branch        @relation("MRSourceBranch", fields: [sourceBranchId], references: [id])
  targetBranch    Branch        @relation("MRTargetBranch", fields: [targetBranchId], references: [id])
  author          User          @relation("AuthoredMergeRequest", fields: [authorId], references: [id])
  comments        MergeComment[]
}

model MergeComment {
  id             String       @id @default(cuid())
  mergeRequestId String
  userId         String
  content        String
  createdAt      DateTime     @default(now())

  mergeRequest   MergeRequest @relation(fields: [mergeRequestId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
}

model BoardComment {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  elementId String?
  content   String
  createdAt DateTime @default(now())

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  boardId   String?
  userId    String
  action    String
  ip        String?
  userAgent String?
  metadata  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([boardId, createdAt])
  @@index([userId, createdAt])
}

model BoardElement {
  id        String   @id @default(cuid())
  boardId   String
  type      String
  x         Float
  y         Float
  width     Float
  height    Float
  rotation  Float    @default(0)
  content   String?
  color     String?
  styles    String?
  zIndex    Int      @default(0)
  locked    Boolean  @default(false)
  groupId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
}

model CommunityDesign {
  id          String   @id @default(cuid())
  title       String
  description String?
  userId      String
  boardId     String?
  thumbnail   String?
  tags        String?
  category    String   @default("general")
  downloadCount Int    @default(0)
  likeCount   Int      @default(0)
  isFeatured  Boolean  @default(false)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([userId])
  @@index([createdAt])
}

model AIAgent {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  systemPrompt String
  model       String   @default("default")
  icon        String?
  color       String   @default("#8b5cf6")
  isPublic    Boolean  @default(false)
  isBuiltIn   Boolean  @default(false)
  config      String?
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ImportJob {
  id          String   @id @default(cuid())
  userId      String
  boardId     String
  fileName    String
  fileType    String
  fileSize    Int
  status      String   @default("pending")
  result      String?
  error       String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([boardId])
}

model BoardInvite {
  id          String   @id @default(cuid())
  boardId     String
  inviterId   String
  email       String
  role        String   @default("EDITOR")
  token       String   @unique
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  inviter     User     @relation("SentInvites", fields: [inviterId], references: [id])

  @@index([token])
  @@index([email])
  @@index([boardId])
}

// ─── Admin: Ad Script Management ──────────────────────────────────────────────

model AdScript {
  id          String   @id @default(cuid())
  name        String
  platform    String                    @default("custom")  // google-adsense, meta, taboola, outbrain, mgid, propellerads, custom
  description String?
  scriptCode  String                    @db.Text
  position    String                    @default("head")   // head, body-start, body-end
  isActive    Boolean                   @default(false)
  priority    Int                       @default(0)
  targeting   String?                   @db.Text           // JSON: { pages: [], countries: [], devices: [] }
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([isActive])
  @@index([platform])
  @@index([priority])
}

// ─── Admin: System Settings ───────────────────────────────────────────────────

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string")   // string, number, boolean, json
  group     String   @default("general")  // general, security, features, branding
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}